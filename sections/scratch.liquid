{% comment %} sections/scratch.liquid {% endcomment %}

{% stylesheet %}
  .featured-products { padding: 40px 0; }
  .featured-products__heading { text-align: center; margin-bottom: 30px; }
  .featured-products__grid {
    display: grid;
    gap: 24px;
  }
  .fp-card { text-decoration: none; color: inherit; display: block; }
  .fp-card__media { position: relative; }
  .fp-card__media img { width: 100%; height: auto; border-radius: 8px; }
  .fp-card__placeholder {
    aspect-ratio: 1; background: #f0f0f0; display: flex;
    align-items: center; justify-content: center; color: #999; border-radius: 8px;
  }
  .fp-card__badge {
    position: absolute; top: 10px; left: 10px;
    background: #c0392b; color: #fff; font-size: 12px;
    padding: 4px 10px; border-radius: 4px;
  }
  .fp-card__title { font-size: 1rem; margin: 12px 0 6px; }
  .fp-card__price s { color: #999; margin-right: 6px; }
{% endstylesheet %}

{% style %}
  #shopify-section-{{ section.id }} .featured-products__grid {
    grid-template-columns: repeat({{ section.settings.product_column }}, minmax(220px, 1fr));
  }
{% endstyle %}

<div class="featured-products page-width">
  <h2 class="featured-products__heading">{{ section.settings.heading }}</h2>

  {% if section.settings.collection != blank %}
    <div class="featured-products__grid">
      {% for product in section.settings.collection.products limit: section.settings.products_to_show %}

        <a href="{{ product.url }}" class="fp-card">
          <div class="fp-card__media">
            {% if product.featured_image %}
              {{ product.featured_image
                 | image_url: width: 500
                 | image_tag:
                     loading: 'lazy',
                     widths: '250, 500',
                     alt: product.title }}
            {% else %}
              <div class="fp-card__placeholder">No image</div>
            {% endif %}

            {{ collection.products.size | money }}

            {% if product.compare_at_price > product.price %}
              <span class="fp-card__badge">Sale</span>
            {% endif %}
          </div>

          <h3 class="fp-card__title">{{ product.title }}</h3>

          <div class="fp-card__price">
            {% if product.compare_at_price > product.price %}
              <s>{{ product.compare_at_price | money }}</s>
            {% endif %}
            <span>{{ product.price | money }}</span>
          </div>
        </a>

      {% else %}
        <p>This collection has no products yet.</p>
      {% endfor %}
    </div>
  {% else %}
    <p>Select a collection in the theme editor to display products.</p>
  {% endif %}
</div>

{% schema %}
{
    "name" : "Featured Products",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Featured Products"
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection to show"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "label": "Products to show",
            "min": 2,
            "max": 12,
            "step": 1,
            "default": 4   
        },
        {
            "type": "range",
            "id": "product_column",
            "label": "Porducts coloumn layout",
            "min": 2,
            "max": 4,
            "step": 1,
            "default": 3
        }
    ],
    "presets": [
        { "name": "Featured Products" }
    ]
}
{% endschema %}